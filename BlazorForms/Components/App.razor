<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0, user-scalable=no, shrink-to-fit=no" />
    <base href="/" />

    <link rel="shortcut icon" href="assets/images/logo/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="/assets/css/app.css" />
    <link href="BlazorForms.styles.css" rel="stylesheet" />


    <link href='/assets/images/logo/apple-touch.png' rel='apple-touch-icon'>
    <link href='/assets/images/logo/apple-touch-57x57.png' rel='apple-touch-icon' sizes='57x57'>
    <link href='/assets/images/logo/apple-touch-72x72.png' rel='apple-touch-icon' sizes='72x72'>
    <link href='/assets/images/logo/apple-touch-76x76.png' rel='apple-touch-icon' sizes='76x76'>
    <link href='/assets/images/logo/apple-touch-114x114.png' rel='apple-touch-icon' sizes='114x114'>
    <link href='/assets/images/logo/apple-touch-120x120.png' rel='apple-touch-icon' sizes='120x120'>
    <link href='/assets/images/logo/apple-touch-144x144.png' rel='apple-touch-icon' sizes='144x144'>
    <link href='/assets/images/logo/apple-touch-152x152.png' rel='apple-touch-icon' sizes='152x152'>
    <link href='/assets/images/logo/apple-touch-180x180.png' rel='apple-touch-icon' sizes='180x180'>
    <link href="_content/Blazor.ContextMenu/blazorContextMenu.min.css" rel="stylesheet" />
    <link href="/site.webmanifest" rel="manifest" />

    <HeadOutlet @rendermode="@InteractiveServer" />
</head>

<body>
    <script src="_content/Microsoft.FluentUI.AspNetCore.Components/js/loading-theme.js" type="text/javascript"></script>
    <loading-theme storage-name="theme"></loading-theme>

    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    
    <script type="text/javascript">
        var item = localStorage.getItem("theme");

        if (item === "light" || item === "dark") {
            localStorage.removeItem("theme");
        }
    </script>

    <script src="assets/extensions/jquery/jquery.min.js"></script>
    <script src="assets/js/blazor-scripts.js"></script>
    <script src="assets/extensions/toastr/toastr.min.js"></script>
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/CKEditor/min.ckeditor.js"></script>
</body>

</html>

