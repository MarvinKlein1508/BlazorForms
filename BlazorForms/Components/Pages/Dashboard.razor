@page "/"
@inject FormService formService
@inject AuthService authService
@inject NavigationManager navigationManager
@inject IStringLocalizer<App> appLocalizer
@inject IStringLocalizer<Dashboard> localizer

<PageTitle>@localizer["PAGETITLE"]</PageTitle>

<h3>@localizer["PAGETITLE"]</h3>

<div class="row">
    <div class="col-lg-3 col-sm-12 order-lg-3">
        <FluentCard Height="auto" AreaRestricted="false">
            <h4>@appLocalizer["FILTER_TITLE"]</h4>
            <EditForm Model="Filter" OnValidSubmit="async () => await LoadAsync(true)">

                <FluentTextField @bind-Value="Filter.SearchPhrase" Label="@appLocalizer["FILTER_PLACEHOLDER_SEARCHTERM"]" Immediate="true" Placeholder="@appLocalizer["FILTER_PLACEHOLDER_SEARCHTERM"]" />



                <label for="form-filter-language">@appLocalizer["LANGUAGE"]</label>
                <InputSelect @bind-Value="Filter.LanguageId" class="fluent-select w-100" id="form-filter-language" aria-placeholder="@appLocalizer["LANGUAGE"]">
                    <option value="0">@appLocalizer["SELECT_ALL"]</option>
                    @foreach (var language in AppdatenService.Languages)
                    {
                        <option value="@language.Id">@language.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => Filter.LanguageId" />


                <FluentButton Class="mt-2" Type="ButtonType.Submit">@appLocalizer["FILTER_BUTTON_SEARCH"]</FluentButton>



            </EditForm>
        </FluentCard>

    </div>
    <div class="col-lg-9 col-sm-12">

        @if (_isLoading)
        {
            <LoadingCircle IsCentered="true" />
        }

        @if (!_isLoading && Data.Count is 0)
        {
            <Alert Color="AlertColor.Danger">@localizer["NO_RESULTS"]</Alert>
        }
        <div class="form-wrapper mb-3">
            @foreach (var item in Data)
            {

                <div class="form-card h-100">
                    <div class="form-card-image">
                        @if (item.Image.Length > 0)
                        {
                            <img src="@($"data:image/png;base64,{Convert.ToBase64String(item.Image)}")" class="card-img-top" alt="@item.Name">
                        }
                        else
                        {
                            <div class="shape bg-line blue w-100 h-18"></div>
                        }
                    </div>
                    <div class="form-card-body">
                        <FluentLabel Typo="Typography.H4" Class="mb-2">@item.Name</FluentLabel>
                        <p>@item.Description</p>
                        <div class="form-card-buttons">
                            <FluentAnchor Href="@($"/Forms/{item.FormId}")" Class="w-100">@localizer["TEXT_BUTTON_FILL_OUT"]</FluentAnchor>
                        </div>
                    </div>
                </div>


            }
        </div>



        @if (TotalPages > 1)
        {
            <Pagination ActivePageNumber="Page"
                        TotalPages="TotalPages"
                        PageChanged="OnPageChangedAsync"
                        FirstLinkIcon="IconName.ChevronDoubleLeft"
                        PreviousLinkIcon="IconName.ChevronLeft"
                        NextLinkIcon="IconName.ChevronRight"
                        LastLinkIcon="IconName.ChevronDoubleRight" />
        }
    </div>
</div>