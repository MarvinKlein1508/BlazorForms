@inherits LayoutComponentBase
@inject AuthService authService
@inject IStringLocalizer<MainLayout> localizer
<PageTitle>BlazorForms</PageTitle>

<div>
    <FluentLayout>
        <FluentHeader Class="siteheader">
            <a href="/">

            </a>
            <FluentSpacer />

            <div class="search">
                <DemoSearch />
            </div>

            
            <div class="notifications">
            </div>
            <div class="settings">
            </div>
        </FluentHeader>

        <FluentStack Class="body-stack" Orientation="Orientation.Horizontal" Width="100%" HorizontalGap="0">
            <DemoNavMenu />
            <FluentBodyContent id="body-content" Style="height: calc(100dvh - 90px);">
                <div class="content">
                    <article id="article">

                        <FluentMessageBarProvider Section="@App.MESSAGES_TOP" />
                        @Body
                    </article>
                    <aside>

                    </aside>

                    <FluentToastProvider MaxToastCount="10" />
                    <FluentDialogProvider />
                    <FluentTooltipProvider />

                </div>
            </FluentBodyContent>
        </FluentStack>

        <FluentFooter Style="@("height: 40px; color: white;")">
            <div class="version">
                <small>
                    Version: 1.0.0
                    &nbsp;-&nbsp;
                    <a href="https://dotnet.microsoft.com/en-us/learn/aspnet/what-is-aspnet-core">Powered by :NET 8.0.1</a>
                </small>
            </div>
            <FluentSpacer />

            <div class="copy">
                <small>Microsoft © 2023. All rights reserved.</small>
            </div>
        </FluentFooter>

    </FluentLayout>
</div>





